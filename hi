<!DOCTYPE html>


<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Pointer Lock – Google Sites friendly</title>
  <style>
    body {
      margin: 0;
      height: 100vh;
      background: #000;
      color: #0f0;
      font-family: Consolas, monospace;
      overflow: hidden;
      cursor: none;
    }
    #instructions {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      background: rgba(0,0,0,0.85);
      font-size: 1.4rem;
      pointer-events: none;
      transition: opacity 0.6s;
    }
    #instructions.hidden {
      opacity: 0;
      pointer-events: none;
    }
    #crosshair {
      position: absolute;
      inset: 50% 0 0 50%;
      width: 20px;
      height: 20px;
      transform: translate(-50%, -50%);
      pointer-events: none;
      opacity: 0.7;
    }
    #debug {
      position: absolute;
      top: 8px;
      left: 12px;
      font-size: 13px;
      color: #0f03;
      pointer-events: none;
    }
  </style>
</head>
<body>

<div id="instructions">
  <div>Click anywhere on this box to lock the mouse</div>
  <div style="margin-top:1.5rem; font-size:1rem; color:#888;">
    Press ESC to unlock • Works best in full window
  </div>
</div>

<div id="crosshair">┼</div>

<div id="debug">waiting for click...</div>

<script>
// ────────────────────────────────────────────────
const instructions = document.getElementById('instructions');
const debug       = document.getElementById('debug');
const crosshair   = document.getElementById('crosshair');

let isLocked = false;

function updateDebug() {
  debug.textContent = `locked = ${isLocked}   •   movementX/Y available = ${'movementX' in MouseEvent.prototype}`;
}

function requestPointerLock() {
  // Most compatible order in 2025–2026
  const elem = document.body;

  if (elem.requestPointerLock) {
    elem.requestPointerLock();
  } else if (elem.webkitRequestPointerLock) {
    elem.webkitRequestPointerLock();
  } else if (elem.mozRequestPointerLock) {
    elem.mozRequestPointerLock();
  }
}

// ─── Events ──────────────────────────────────────
document.addEventListener('click', (e) => {
  if (!isLocked) {
    requestPointerLock();
  }
});

document.addEventListener('pointerlockchange', pointerLockChange);
document.addEventListener('mozpointerlockchange', pointerLockChange);
document.addEventListener('webkitpointerlockchange', pointerLockChange);

function pointerLockChange() {
  const locked =
    document.pointerLockElement === document.body ||
    document.mozPointerLockElement === document.body ||
    document.webkitPointerLockElement === document.body;

  isLocked = locked;
  updateDebug();

  instructions.classList.toggle('hidden', locked);
  crosshair.style.opacity = locked ? '0.7' : '0.2';
}

document.addEventListener('mousemove', (e) => {
  if (!isLocked) return;

  // movementX/Y should appear only when locked
  const mx = e.movementX || e.mozMovementX || e.webkitMovementX || 0;
  const my = e.movementY || e.mozMovementY || e.webkitMovementY || 0;

  if (mx !== 0 || my !== 0) {
    debug.textContent = `dx:\( {mx.toString().padStart(4)}  dy: \){my.toString().padStart(4)}`;
  }
});

// Optional: unlock with ESC is automatic, but we can listen
document.addEventListener('keydown', e => {
  if (e.key === 'Escape' || e.key === 'Esc') {
    // Most browsers exit pointer lock on ESC automatically
    // but we can force it for safety
    if (document.exitPointerLock) {
      document.exitPointerLock();
    } else if (document.webkitExitPointerLock) {
      document.webkitExitPointerLock();
    } else if (document.mozExitPointerLock) {
      document.mozExitPointerLock();
    }
  }
});

updateDebug();
</script>
</body>
</html>




